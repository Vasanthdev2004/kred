# Copy to .env.local for local dev. All values here are safe placeholders.

# WalletConnect project id (optional). Injected wallets (MetaMask) work without it.
# Get one free at https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=PAYSLIP_DEMO

# Public app URL (used to build shareable request / verify links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Prisma (M2+). SQLite locally; swap for Postgres when deployed.
DATABASE_URL="file:./dev.db"
